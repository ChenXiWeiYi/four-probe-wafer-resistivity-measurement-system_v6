    <property name="styleSheet">
      <string notr="true">QWidget { font-family: "Microsoft YaHei", "SimSun"; font-size: 10pt; }
QFrame#frameTopStatus, QFrame#frameSideNav { border: 1px solid #b9b9b9; border-radius: 2px; background-color: #f5f5f5; }
QGroupBox { font-weight: 600; margin-top: 8px; padding-top: 12px; }
QGroupBox::title { subcontrol-origin: margin; left: 10px; padding: 0 4px; }
QPushButton, QToolButton { min-height: 24px; padding: 3px 10px; }
QLineEdit { min-height: 22px; padding: 2px 4px; }
QTableWidget, QTextEdit { background-color: white; }
QLabel#Label_VoltData, QLabel#Label_CurrData, QLabel#lblRealtimeResistance, QLabel#Label_ResData, QLabel#Label_MeasureProgress, QLabel#Label_Current, QLabel#lblAverageValue, QLabel#lblStdValue, QLabel#lblFinalResistivity, QLabel#lblWS, QLabel#lblSD, QLabel#lblGeometryFactor, QLabel#lblTemperatureFactor, QLabel#lblTotalFactor { font-family: "Consolas"; font-size: 13pt; font-weight: 600; }
QLabel#lblConnectStatus, QLabel#lblCurrentRange, QLabel#lblVoltageRange, QLabel#lblMeasureMode, QLabel#lblMeasureState { font-weight: 600; }
QLabel#lblNavTitle { font-weight: 600; }
QPushButton#Button_MeasStart { font-weight: 600; min-height: 30px; }</string>
    </property>
