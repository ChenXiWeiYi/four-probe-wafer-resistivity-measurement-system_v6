    <widget class="QToolButton" name="Button_CurrPos">
     <property name="geometry">
      <rect>
       <x>480</x>
       <y>330</y>
       <width>230</width>
       <height>50</height>
      </rect>
     </property>
     <property name="sizePolicy">
      <sizepolicy hsizetype="Fixed" vsizetype="Fixed">
       <horstretch>0</horstretch>
       <verstretch>0</verstretch>
      </sizepolicy>
     </property>
