     <property name="styleSheet">
      <string notr="true">QToolButton {
    /* --- 原有样式 --- */
    border-color: rgb(100, 100, 100);
    border-width: 2px;
    border-style: solid;
    background-color: rgb(225, 225, 225);
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;;
    font-size: 14pt;
    font-weight: bold;
    color: black;

    /* --- 推荐优化样式 --- */
    padding: 5px 15px;       /* 上下 5px，左右 15px 内边距，防止文字贴边 */
    border-radius: 4px;      /* 4 像素圆角，让按钮不那么生硬 */
}

/* 鼠标移上去的效果 */
QToolButton:hover {
    background-color: rgb(240, 240, 240); /* 背景变亮，提示可交互 */
    border-color: rgb(80, 80, 80);        /* 边框稍微加深 */
}

/* 鼠标按下去的效果 */
QToolButton:pressed {
    background-color: rgb(200, 200, 200); /* 背景变暗，模拟凹陷 */
    border-color: rgb(60, 60, 60);        /* 边框更深 */
    
    /* 模拟按钮被按下的位移感 (可选) */
    padding-top: 6px;     
    padding-left: 16px;   
}</string>
