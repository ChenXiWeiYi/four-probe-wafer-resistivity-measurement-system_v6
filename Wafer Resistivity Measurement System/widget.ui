         <size>
          <width>120</width>
          <height>40</height>
         </size>
        </property>
        <property name="styleSheet">
         <string notr="true">QPushButton {
    /* --- 原有样式 --- */
    border-color: rgb(100, 100, 100);
    border-width: 2px;
    border-style: solid;
    background-color: rgb(215, 215, 215);
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;;
    font-size: 14pt;
    font-weight: bold;
    color: black;

    /* --- 推荐优化样式 --- */
    padding: 5px 15px;       /* 上下 5px，左右 15px 内边距，防止文字贴边 */
    border-radius: 4px;      /* 4 像素圆角，让按钮不那么生硬 */
}

/* 鼠标移上去的效果 */
QPushButton:hover {
    background-color: rgb(230, 230, 230); /* 背景变亮，提示可交互 */
    border-color: rgb(80, 80, 80);        /* 边框稍微加深 */
}

/* 鼠标按下去的效果 */
QPushButton:pressed {
    background-color: rgb(190, 190, 190); /* 背景变暗，模拟凹陷 */
    border-color: rgb(60, 60, 60);        /* 边框更深 */
    
    /* 模拟按钮被按下的位移感 (可选) */
    padding-top: 6px;     
    padding-left: 16px;   
}</string>
        </property>
        <property name="text">
         <string>P</string>
        </property>
        <property name="fixedSize" stdset="0">
         <size>
          <width>100</width>
          <height>50</height>
         </size>
        </property>
       </widget>
